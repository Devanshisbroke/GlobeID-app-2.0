# Production frontend → backend base URL.
#
# Required for Capacitor APK builds: when this is unset, the client falls
# back to http://localhost:4000/api/v1 which the device cannot reach.
#
# Usage:
#   1. Copy this file to .env.production
#   2. Set VITE_API_BASE_URL to your public API endpoint
#      (e.g. Cloudflare Tunnel, Railway, Fly.io, your own VPS)
#   3. `npm run build`         (or `npm run build -- --mode production`)
#   4. `npx cap sync android`
#   5. `cd android && ./gradlew assembleDebug`
#
# Vite reads .env.production automatically when --mode is production
# (which is the default for `vite build`).
VITE_API_BASE_URL=https://your-api-host.example.com/api/v1
